# Aspace Backend Environment Configuration

# Server
NODE_ENV=development
API_PORT=3001
API_BASE_PATH=/api/v1

# CORS - comma-separated origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aspace

# Optional Platform Settings
# ASPACE_FEE_BPS=150  # Platform fee in basis points (1.5% = 150)
# ASPACE_FEE_WALLET=0x...  # Wallet address to collect fees

# Blockchain (optional, for on-chain indexing or verification)
# KITE_AI_RPC_URL=https://rpc.kite-testnet.io
# KITE_AI_CHAIN_ID=12345
# USDC_CONTRACT_ADDRESS=0x...

# Redis (optional, for caching and queues)
# REDIS_URL=redis://localhost:6379

# Monitoring
# SENTRY_DSN=...

# The backend uses PostgreSQL for off-chain metadata, with a fallback in-memory store when DB is unavailable.
# See the main README.md for full setup instructions.
